    },

    {
      "name": "Get All Customers",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{base_url}}/customers?page=1&limit=5&search=",
          "host": ["{{base_url}}"],
          "path": ["customers"],
          "query": [
            {
              "key": "page",
              "value": "1"
            },
            {
              "key": "limit",
              "value": "5"
            },
            {
              "key": "search",
              "value": ""
            }
          ]
        }
      }
    },

    {
      "name": "Get Customer By ID",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{base_url}}/customers/{{customer_id}}",
          "host": ["{{base_url}}"],
          "path": [
